{
  "version": 2,
  "functions": {
    "**.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    { "source": "/:path*", "destination": "/index.php" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
